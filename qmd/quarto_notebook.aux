\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Spatial coverage of the non-broadcasting emissions model. Areas are classified according to whether they fall inside or outside the S1 footprint and whether they have been imaged by S1 at any point in time. A given pixel may be imaged in some months but not in others. Pixels outside the footprint have never been imaged. The percentage of total CO\(_{2}\) emissions from non-broadcasting vessels attributed to each category is shown.}}{21}{figure.caption.15}\protected@file@percent }
\newlabel{fig-spatial-coverage-footprint}{{14}{21}{Spatial coverage of the non-broadcasting emissions model. Areas are classified according to whether they fall inside or outside the S1 footprint and whether they have been imaged by S1 at any point in time. A given pixel may be imaged in some months but not in others. Pixels outside the footprint have never been imaged. The percentage of total CO\(_{2}\) emissions from non-broadcasting vessels attributed to each category is shown}{figure.caption.15}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.0.3}Registered data validation}{22}{subsubsection.3.0.3}\protected@file@percent }
\newlabel{registered-data-validation}{{3.0.3}{22}{Registered data validation}{subsubsection.3.0.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Comparison of registered and simulated CO\(_{2}\) emissions from main engine fuel consumption over 24 hours. Estimates are shown using main engine power and design speed from IMO (left), our machine learning random forest models (center), and the same registered dataset (right). The solid red line shows a linear regression fit, while the dashed line represents the 1:1 line. Performance values for traditional R\(^{2}\) are shown for each set of vessel characteristics. Blue shading indicates point density. All data are rule-of-three compliant, meaning each cell (20×20 mt) displayed contains at least three vessels.}}{22}{figure.caption.16}\protected@file@percent }
\newlabel{fig-registered-data-performance}{{15}{22}{Comparison of registered and simulated CO\(_{2}\) emissions from main engine fuel consumption over 24 hours. Estimates are shown using main engine power and design speed from IMO (left), our machine learning random forest models (center), and the same registered dataset (right). The solid red line shows a linear regression fit, while the dashed line represents the 1:1 line. Performance values for traditional R\(^{2}\) are shown for each set of vessel characteristics. Blue shading indicates point density. All data are rule-of-three compliant, meaning each cell (20×20 mt) displayed contains at least three vessels}{figure.caption.16}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.0.4}MRV validation}{23}{subsubsection.3.0.4}\protected@file@percent }
\newlabel{mrv-validation}{{3.0.4}{23}{MRV validation}{subsubsection.3.0.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Comparison of published MRV emissions and simulated CO\(_{2}\) emissions. The sample includes 2,276 observations from yearly aggregated vessel trips where hours at sea differ by no more than 15\% between our data and the MRV dataset. The solid red line shows the linear regression fit, and the dashed line represents the 1:1 line.\}.}}{23}{figure.caption.17}\protected@file@percent }
\newlabel{fig-mrv-performance}{{16}{23}{Comparison of published MRV emissions and simulated CO\(_{2}\) emissions. The sample includes 2,276 observations from yearly aggregated vessel trips where hours at sea differ by no more than 15\% between our data and the MRV dataset. The solid red line shows the linear regression fit, and the dashed line represents the 1:1 line.\}}{figure.caption.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Summary of dark fleet model performance metrics for the: 1) emissions regression model; 2) detections classification mode; and 3) detections regression model. Performance estimates for each metric are shown for both the inside S1 footprint and outside S1 footprint tests. All metrics are calculated at the unit of observation except for 'Percent error of total summed predictions', which is the percentage error in the total sum of all predictions relative to the total sum of all truth values.}}{24}{table.caption.18}\protected@file@percent }
\newlabel{tab:all_performance_metrics_table}{{3}{24}{Summary of dark fleet model performance metrics for the: 1) emissions regression model; 2) detections classification mode; and 3) detections regression model. Performance estimates for each metric are shown for both the inside S1 footprint and outside S1 footprint tests. All metrics are calculated at the unit of observation except for 'Percent error of total summed predictions', which is the percentage error in the total sum of all predictions relative to the total sum of all truth values}{table.caption.18}{}}
